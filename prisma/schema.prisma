generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LivePlatform {
  TWITCH
  YOUTUBE
  KICK
}

enum LiveStatus {
  PENDING
  APPROVED
  REJECTED
  CHANGES_REQUESTED
}

model LiveRequest {
  id               String         @id @default(cuid())
  discordId        String
  discordUsername  String
  discordAvatar    String?
  liveName         String
  platform         LivePlatform
  liveUrl          String
  startTime        String
  description      String
  status           LiveStatus     @default(PENDING)
  rejectionReason  String?
  changeRequest    String?
  discordMessageId String?
  discordChannelId String?
  createdAt        DateTime       @default(now())
  approvedAt       DateTime?
  updatedAt        DateTime       @updatedAt
  adminLogs        AdminLog[]
  notifications    Notification[]

  @@index([discordId])
  @@index([status])
  @@index([createdAt])
}

model AdminLog {
  id          String       @id @default(cuid())
  action      String
  adminId     String
  adminTag     String?
  liveId      String?
  metadata    Json?
  createdAt   DateTime     @default(now())
  liveRequest LiveRequest? @relation(fields: [liveId], references: [id], onDelete: SetNull)

  @@index([adminId])
  @@index([createdAt])
}

model Notification {
  id          String       @id @default(cuid())
  discordId   String
  title       String
  message     String
  read        Boolean      @default(false)
  liveId      String?
  createdAt   DateTime     @default(now())
  liveRequest LiveRequest? @relation(fields: [liveId], references: [id], onDelete: Cascade)

  @@index([discordId])
  @@index([read])
  @@index([createdAt])
}

model LiveAlertConfig {
  id                String   @id @default(cuid())
  userIdDiscord     String   @map("user_id_discord")
  guildId           String   @map("guild_id")
  streamerUrl       String   @map("streamer_url")
  streamerName      String   @map("streamer_name")
  twitchUserId      String?  @map("twitch_user_id")
  twitchAvatarUrl   String?  @map("twitch_avatar_url")
  textChannelId     String   @map("text_channel_id")
  customMessage     String   @map("custom_message")
  enabled           Boolean  @default(true)
  lastStreamId      String?  @map("last_stream_id")
  lastLiveStartedAt DateTime? @map("last_live_started_at")
  lastAlertSentAt   DateTime? @map("last_alert_sent_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@unique([guildId, streamerName])
  @@index([userIdDiscord])
  @@index([guildId])
  @@index([enabled])
  @@map("live_alert_configs")
}

model TwitchSubConfig {
  id                        String   @id @default(cuid())
  guildId                   String   @unique @map("guild_id")
  broadcasterLogin          String?  @map("broadcaster_login")
  broadcasterId             String?  @map("broadcaster_id")
  broadcasterAccessToken    String?  @map("broadcaster_access_token")
  broadcasterRefreshToken   String?  @map("broadcaster_refresh_token")
  broadcasterTokenExpiresAt DateTime? @map("broadcaster_token_expires_at")
  primeRoleId               String?  @map("prime_role_id")
  tier1RoleId               String?  @map("tier1_role_id")
  tier2RoleId               String?  @map("tier2_role_id")
  tier3RoleId               String?  @map("tier3_role_id")
  logChannelId              String?  @map("log_channel_id")
  syncIntervalHours         Int      @default(12) @map("sync_interval_hours")
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")

  @@index([guildId])
  @@map("twitch_sub_configs")
}

model TwitchLinkedAccount {
  id                    String   @id @default(cuid())
  guildId               String   @map("guild_id")
  discordUserId         String   @map("discord_user_id")
  twitchUserId          String   @map("twitch_user_id")
  twitchLogin           String   @map("twitch_login")
  twitchDisplayName     String   @map("twitch_display_name")
  twitchAccessToken     String?  @map("twitch_access_token")
  twitchRefreshToken    String?  @map("twitch_refresh_token")
  twitchTokenExpiresAt  DateTime? @map("twitch_token_expires_at")
  active                Boolean  @default(false)
  tier                  String?
  roleId                String?  @map("role_id")
  isGift                Boolean? @map("is_gift")
  lastCheckedAt         DateTime? @map("last_checked_at")
  lastSubscribedAt      DateTime? @map("last_subscribed_at")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@unique([guildId, discordUserId])
  @@unique([guildId, twitchUserId])
  @@index([guildId])
  @@index([active])
  @@map("twitch_linked_accounts")
}

model TwitchSubSyncLog {
  id            String   @id @default(cuid())
  guildId       String   @map("guild_id")
  discordUserId String?  @map("discord_user_id")
  twitchUserId  String?  @map("twitch_user_id")
  action        String
  message       String
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([guildId])
  @@index([createdAt])
  @@map("twitch_sub_sync_logs")
}
